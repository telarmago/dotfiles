{
    // General
    "editor.fontFamily": "SF Mono",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "terminal.integrated.fontSize": 14,
    "editor.rulers": [80],
    "files.associations": {
        "*.txt": "markdown",
    },
    "editor.multiCursorModifier": "ctrlCmd",
    "window.newWindowDimensions": "inherit",
    "window.confirmBeforeClose": "always",
    "files.trimTrailingWhitespace": true,
    "editor.formatOnPaste": true,
    "extensions.ignoreRecommendations": true,
    "zenMode.fullScreen": false,
    "zenMode.hideLineNumbers": false,
    "diffEditor.renderSideBySide": true,

    // Layout
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "workbench.activityBar.location": "top",
    "chat.commandCenter.enabled": false,
    "workbench.statusBar.visible": false,
    "window.title": " ",
    "terminal.integrated.tabs.description": "",

    // Debug
    "debug.toolBarLocation": "docked",
    "debug.console.fontSize": 14,

    // Theme
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "workbench.colorTheme": "Material Theme Darker High Contrast",

    // Other
    "editor.guides.bracketPairs": "active",
    "editor.lightbulb.enabled": "off",
    "editor.accessibilitySupport": "off",
    "workbench.editor.enablePreview": true,
    "workbench.editor.wrapTabs": true,
    // "workbench.editor.tabSizing": "fixed",
    // "workbench.editor.tabSizingFixedMinWidth": 160,
    // "workbench.editor.tabSizingFixedMaxWidth": 160,

    // Terminal
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.commandsToSkipShell": [
        "-workbench.action.quickOpenView"
    ],
    "terminal.integrated.macOptionIsMeta": true,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.scrollback": 10000,

    // Meta
    "biggrep.hideUninteresting.enabled": true,
    "hg.openSidebarOnMergeConflictsMode": "Never",
    "bento.openHackNotebookWithDebugger": false,

    // Devmate
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "editor.inlineSuggest.allowSuggestOnTriggerCharacters": true,
    "accessibility.openChatEditedFiles": false,
    "devmate.inline.assertiveness.enable-inline-buttons-highlighted-text": false,
    "devmate.sidebar.extendedThinkingEnabled": true,
    "devmate.sidebar.interleavedThinkingEnabled": true,
    "devmate.sidebar.defaultModel": "Claude Opus 4.5",
    "devmate.sidebar.gpt5.reasoningEffort": "HIGH",
    "terminal.integrated.showDevmateSelectionButton": false,
    "terminal.integrated.showDevmateQuickFixButton": false,
    "devmate.sidebar.open-on-startup": false,
}
